<%- include('partials/header') %>

<main>
  <div class="detail-section">
    <a href="/aliments" class="btn-retour">← Retour aux aliments</a>

    <!-- "aliment" vaut null si l'id demandé dans l'URL ne correspond à aucun aliment en base (voir index.js) -->
    <% if (aliment) { %>
    <div class="detail-carte">
      <!-- On affiche la vraie photo si elle existe, sinon l'emoji comme solution de secours -->
      <div class="detail-image">
        <% if (aliment.image) { %>
        <img src="/<%= aliment.image %>" alt="<%= aliment.nom %>" class="detail-image__photo" />
        <% } else { %>
        <%= aliment.emoji %>
        <% } %>
      </div>

      <div class="detail-infos">
        <p class="detail-categorie"><%= aliment.categorie %></p>
        <h1 class="detail-nom"><%= aliment.nom %></h1>

        <!-- Ces deux informations sont facultatives : on ne les affiche que si elles existent en base -->
        <% if (aliment.origine) { %>
        <p class="detail-origine">Origine : <%= aliment.origine %></p>
        <% } %>

        <% if (aliment.description) { %>
        <p class="detail-description"><%= aliment.description %></p>
        <% } %>

        <!-- Les 4 valeurs nutritionnelles principales, pour 100g de cet aliment -->
        <div class="detail-macros">
          <div class="macro-card macro-calories">
            <span class="macro-valeur"><%= aliment.calories %></span>
            <span class="macro-label">kcal</span>
          </div>
          <div class="macro-card">
            <span class="macro-valeur"><%= aliment.glucides %>g</span>
            <span class="macro-label">Glucides</span>
          </div>
          <div class="macro-card">
            <span class="macro-valeur"><%= aliment.proteines %>g</span>
            <span class="macro-label">Protéines</span>
          </div>
          <div class="macro-card">
            <span class="macro-valeur"><%= aliment.lipides %>g</span>
            <span class="macro-label">Lipides</span>
          </div>
        </div>

        <!-- Poids d'une cuillère de CET aliment précis : ça n'a rien d'universel (1 c. à soupe
             d'huile ≈ 13g, 1 c. à soupe de gomme xanthane ≈ 9g), donc renseigné une fois ici,
             au poids réel constaté à la cuisine. Sert ensuite à saisir "1/2 c. à café" plutôt que
             de deviner un poids en grammes, dans le Journal et les recettes (voir calories.js). -->
        <!-- <details> plutôt qu'affiché en permanence : repliée par défaut, elle n'a plus l'air de
             "redemander" une équivalence à chaque aliment (carotte, poulet...) qui ne s'y prête
             jamais — on l'ouvre seulement pour les quelques aliments concernés (huile, épices...). -->
        <details class="detail-equivalences" data-id="<%= aliment.id %>">
          <summary class="detail-equivalences__titre">Équivalences (poids d'une cuillère)</summary>
          <p class="detail-equivalences__aide">Laisse vide tant que tu ne l'as pas pesé toi-même — sans valeur, seuls les grammes restent proposés.</p>
          <div class="detail-equivalences__champs">
            <label>
              1 c. à café =
              <input type="number" id="equivGrammesCafe" min="0" step="0.1" placeholder="g" value="<%= aliment.grammes_par_cuil_a_cafe ?? '' %>" />
              g
            </label>
            <label>
              1 c. à soupe =
              <input type="number" id="equivGrammesSoupe" min="0" step="0.1" placeholder="g" value="<%= aliment.grammes_par_cuil_a_soupe ?? '' %>" />
              g
            </label>
          </div>
          <p class="detail-equivalences__statut hidden" id="equivStatut"><span class="icone-reussi"></span> Enregistré</p>
        </details>
      </div>
    </div>
    <% } else { %>
    <!-- Message affiché si aucun aliment ne correspond à l'id demandé -->
    <p class="not-found">Aliment introuvable.</p>
    <% } %>
  </div>
</main>

<% if (aliment) { %>
<script src="/js/aliment-detail.js" defer></script>
<% } %>

<%- include('partials/footer') %>
