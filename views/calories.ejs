<%- include('partials/header') %>

<%
  // Ce bloc de code (sans le signe =) exécute du JavaScript côté serveur, sans rien afficher directement.
  // On calcule ici les totaux du jour en additionnant les valeurs de chaque entrée du journal (reduce = "additionner tout").
  const totalKcal = journal.reduce((sum, j) => sum + Number(j.calories_calc), 0);
  const totalGlucides = journal.reduce((sum, j) => sum + Number(j.glucides_calc), 0);
  const totalProteines = journal.reduce((sum, j) => sum + Number(j.proteines_calc), 0);
  const totalLipides = journal.reduce((sum, j) => sum + Number(j.lipides_calc), 0);
  // On trie les aliments par ordre alphabétique pour la liste de suggestions d'ingrédients (recette)
  const alimentsTries = [...aliments].sort((a, b) => a.nom.localeCompare(b.nom));
  // Les deux catégories de recette sont un ensemble fermé (voir le sélecteur du panneau détail,
  // qui n'offre que ces deux boutons) : on les fixe ici plutôt que de les déduire des recettes
  // existantes, sinon une catégorie sans aucune recette n'aurait jamais sa propre section.
  const CATEGORIES_RECETTE = [
    { valeur: "boisson", icone: "🍨", label: "Boissons" },
    { valeur: "plat", icone: "🍽️", label: "Plats" }
  ];
%>

<main>
  <div class="journal-section">
    <h1>Compter sans <span>culpabiliser.</span></h1>
    <p class="page-header__description">Chaque bouchée a le droit d'être notée — sauf la troisième part de gâteau, on garde un œil dessus.</p>

    <!-- Les 4 totaux du jour, calculés ci-dessus. Les id (totalKcal, etc.) permettent
         au JavaScript (calories.js) de les mettre à jour en direct sans recharger la page -->
    <div class="journal-totaux">
      <div class="macro-card macro-calories">
        <span class="macro-valeur" id="totalKcal"><%= totalKcal.toFixed(0) %></span>
        <span class="macro-label">kcal</span>
      </div>
      <div class="macro-card">
        <span class="macro-valeur" id="totalGlucides"><%= totalGlucides.toFixed(1) %>g</span>
        <span class="macro-label">Glucides</span>
      </div>
      <div class="macro-card">
        <span class="macro-valeur" id="totalProteines"><%= totalProteines.toFixed(1) %>g</span>
        <span class="macro-label">Protéines</span>
      </div>
      <div class="macro-card">
        <span class="macro-valeur" id="totalLipides"><%= totalLipides.toFixed(1) %>g</span>
        <span class="macro-label">Lipides</span>
      </div>
    </div>

    <!-- Journal et Recettes sont deux onglets de la même page (pas des routes séparées) :
         changer d'onglet ne recharge rien, voir calories.js -->
    <div class="calories-tabs">
      <button type="button" class="calories-tab-btn actif" data-tab="journal">Journal</button>
      <button type="button" class="calories-tab-btn" data-tab="recettes">Recettes</button>
    </div>

    <!-- ============================================ -->
    <!-- ONGLET JOURNAL -->
    <!-- ============================================ -->
    <div class="calories-tab-panel actif" data-panel="journal">

      <div class="journal-actions-row">
        <!-- Champ de recherche + liste de suggestions pour ajouter instantanément un aliment au journal -->
        <div id="autocompleteCalories">
          <input type="text" id="rechercheAlimentCalories" placeholder="Rechercher un aliment..." autocomplete="off" />
          <ul id="listeAlimentsCalories">
            <% aliments.forEach(function(aliment) { %>
            <li data-id="<%= aliment.id %>">
              <%= aliment.emoji %> <%= aliment.nom %>
            </li>
            <% }) %>
          </ul>
        </div>

        <!-- Menu déroulant pour appliquer directement une recette (remplace le journal du jour par ses ingrédients).
             Icône plutôt que texte : "Recette" se lisait comme un doublon de l'onglet "Recettes"
             juste au-dessus. aria-label garde l'action compréhensible pour les lecteurs d'écran
             malgré l'absence de texte visible (voir custom-selects.js). -->
        <select id="selectRecette" aria-label="Remplacer le journal du jour avec une recette">
          <option value=""></option>
          <% recettes.forEach(function(recette) { %>
          <option value="<%= recette.id %>"><%= recette.nom %></option>
          <% }) %>
        </select>

        <!-- Bouton rond "X" (plutôt qu'un texte "Tout effacer") : même langage que les autres
             icônes de suppression de l'app -->
        <button type="button" id="btnToutEffacer" class="btn-x-rond" title="Tout effacer">Tout effacer</button>
      </div>

      <!-- Caché par défaut : n'apparaît que si le journal du jour a 3 aliments ou plus ET que
           cette combinaison exacte ne correspond à aucune recette déjà enregistrée (voir calories.js) -->
      <button type="button" id="btnEnregistrerRecette" class="btn-enregistrer-recette hidden"></button>

      <!-- Liste des aliments déjà mangés aujourd'hui, générée côté serveur -->
      <div id="listeJournal">
        <% journal.forEach(function(entree) { %>
        <!-- Les valeurs nutritionnelles sont stockées dans des attributs data-*, réutilisées par calories.js
             pour recalculer les totaux sans avoir à redemander ces infos au serveur -->
        <div class="journal-item carte-article" data-id="<%= entree.id %>" data-food-id="<%= entree.food_id %>" data-kcal="<%= entree.calories_calc %>" data-glucides="<%= entree.glucides_calc %>" data-proteines="<%= entree.proteines_calc %>" data-lipides="<%= entree.lipides_calc %>" data-g-cafe="<%= entree.grammes_par_cuil_a_cafe ?? '' %>" data-g-soupe="<%= entree.grammes_par_cuil_a_soupe ?? '' %>" data-quantite-g="<%= parseFloat(entree.quantite_g) %>">
          <div class="journal-nom-groupe">
            <span class="journal-nom"><%= entree.emoji %> <%= entree.nom %></span>
            <span class="journal-categorie"><%= entree.categorie %></span>
          </div>
          <div class="journal-valeurs">
            <!-- Champ modifiable : changer la quantité met à jour les calories en direct (voir calories.js).
                 Le sélecteur d'unité est toujours affiché (même juste "g" seul) : chaque ligne
                 a la même forme, plutôt que certaines lignes ayant un menu et d'autres non. -->
            <div class="journal-quantite-groupe">
              <input type="number" class="journal-grammes-input" step="0.25" value="<%= parseFloat(entree.quantite_g) %>" min="0.25" />
              <select class="journal-unite-select">
                <option value="g">g</option>
                <% if (entree.grammes_par_cuil_a_cafe) { %><option value="cafe">tsp</option><% } %>
                <% if (entree.grammes_par_cuil_a_soupe) { %><option value="soupe">tbsp</option><% } %>
              </select>
            </div>
            <span class="journal-kcal"><%= Number(entree.calories_calc).toFixed(0) %> kcal</span>
          </div>
          <!-- Formulaire de suppression, intercepté par le JavaScript pour l'envoyer sans recharger la page -->
          <form action="/calories/supprimer" method="post" class="form-supprimer-journal">
            <input type="hidden" name="idEntree" value="<%= entree.id %>" />
            <button type="submit" class="btn-supprimer-dash">Supprimer</button>
          </form>
        </div>
        <% }) %>
      </div>

      <!-- Message affiché uniquement quand le journal du jour est vide -->
      <p class="no-results hidden" id="noResultsJournal">Rien d'ajouté aujourd'hui.</p>
    </div>

    <!-- ============================================ -->
    <!-- ONGLET RECETTES -->
    <!-- ============================================ -->
    <div class="calories-tab-panel" data-panel="recettes">

      <!-- Deux blocs bien séparés (pas un simple filtre) : les boissons et les plats ne se
           mélangent jamais visuellement, même dans la vue par défaut -->
      <% CATEGORIES_RECETTE.forEach(function(cat) { %>
      <section class="recette-groupe">
        <h3 class="recette-groupe-titre"><%= cat.icone %> <%= cat.label %></h3>
        <div class="recette-grid" data-grid-cat="<%= cat.valeur %>">
          <% recettes.filter(function(r) { return r.categorie === cat.valeur; }).forEach(function(recette) { %>
          <div class="recette-card" data-id="<%= recette.id %>" data-cat="<%= recette.categorie %>">
            <!-- Pas de bouton "éditer" NI "supprimer" sur la carte : toucher la carte ouvre le
                 panneau de détail, et c'est SEULEMENT depuis ce panneau qu'on peut supprimer la
                 recette (bouton poubelle à côté du "✕" fermer, voir plus bas) -->
            <span class="recette-emoji"><%= cat.icone %></span>
            <p class="recette-nom"><%= recette.nom %></p>
            <div class="recette-sub"><span><%= recette.nb_ingredients %> ingr.</span><span><%= recette.kcal_total %> kcal</span></div>
          </div>
          <% }) %>
          <div class="recette-card recette-new-card btn-nouvelle-recette" data-nouvelle-cat="<%= cat.valeur %>">
            <span class="recette-new-plus">+</span>
            <span>Nouvelle recette</span>
          </div>
        </div>
      </section>
      <% }) %>
    </div>

  </div>
</main>

<!-- ============================================ -->
<!-- PANNEAU DÉTAIL D'UNE RECETTE (overlay, pas un onglet) -->
<!-- ============================================ -->
<div class="sheet-backdrop" id="sheetBackdrop"></div>
<div class="sheet" id="sheet">
  <div class="sheet-handle"></div>
  <form id="formRecette">
    <input type="hidden" id="recetteId" value="" />

    <div class="detail-header">
      <input type="text" id="recetteNom" class="detail-nom-edit" placeholder="Nom de la recette" required />
      <div class="detail-header-actions">
        <button type="button" id="sheetCloseBtn" class="sheet-close-btn" title="Fermer">✕</button>
      </div>
    </div>

    <!-- Boisson/Plat à gauche, "+" à droite sur la même ligne : le "+" ouvre/ferme la recherche
         d'ingrédient, repliée par défaut, même principe que les panneaux d'ajout de Stock/Courses. -->
    <div class="detail-tag-row">
      <div class="detail-tag-select" id="recetteCategoriePicker">
        <button type="button" class="cat-pill actif" data-valeur="boisson">🍨 Boisson</button>
        <button type="button" class="cat-pill" data-valeur="plat">🍽️ Plat</button>
      </div>
      <button type="button" id="btnToggleAjoutIngredient" class="btn-ajout-icone" title="Ajouter un ingrédient">Ajouter un ingrédient</button>
    </div>

    <div id="listeIngredientsRecette">
      <!-- Toujours le DERNIER enfant de la liste (voir ajouterLigneIngredient dans calories.js,
           qui insère chaque nouvelle ligne juste AVANT ce champ plutôt qu'après) : la recherche
           s'ouvre donc littéralement sous le dernier ingrédient ajouté, à l'intérieur de la
           même zone qui défile, plutôt qu'en dehors dans une zone fixe séparée. -->
      <div id="autocompleteIngredient" class="replie">
        <input type="text" id="rechercheIngredient" placeholder="Rechercher un aliment à ajouter..." autocomplete="off" />
        <ul id="listeIngredientsRecherche">
          <% alimentsTries.forEach(function(aliment) { %>
          <li data-id="<%= aliment.id %>" data-emoji="<%= aliment.emoji %>" data-g-cafe="<%= aliment.grammes_par_cuil_a_cafe ?? '' %>" data-g-soupe="<%= aliment.grammes_par_cuil_a_soupe ?? '' %>"><%= aliment.emoji %> <%= aliment.nom %></li>
          <% }) %>
        </ul>
      </div>
    </div>

    <!-- Affiché tant que la liste est vide (voir majEtatIngredients dans calories.js), pour ne
         pas laisser un grand vide silencieux avant d'avoir ajouté le premier ingrédient -->
    <p class="ingredients-vide" id="ingredientsVide">Aucun ingrédient pour l'instant — touche "+" pour en ajouter.</p>

    <button type="submit" id="btnEnregistrerSheet">Enregistrer</button>

    <!-- Séparée du "✕" fermer (en haut) : façon Apple (ex. "Delete Contact"), une action
         destructive ne vit jamais collée à un bouton de fermeture/annulation, pour ne jamais
         la déclencher par un tap malheureux. Cachée pour "Nouvelle recette" (rien à supprimer
         avant le premier enregistrement), affichée en mode édition (voir calories.js). -->
    <button type="button" id="btnSupprimerRecetteSheet" class="btn-supprimer-pleine-largeur hidden">
      Supprimer la recette
    </button>
  </form>
</div>

<script>
  // Copie des recettes (avec leurs food_ids) disponible côté client, pour savoir si la
  // combinaison actuellement notée dans le journal correspond déjà à une recette existante
  // (voir miseAJourBoutonEnregistrerRecette dans calories.js), sans redemander au serveur.
  window.RECETTES = <%- JSON.stringify(recettes) %>;
</script>
<script src="/js/calories.js" defer></script>

<%- include('partials/footer') %>
