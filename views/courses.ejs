<%- include('partials/header') %>

<main>
  <div class="page-header">
    <h1>La liste qui <span>n'oublie jamais.</span></h1>
    <p class="page-header__description">Toi si, elle non. Ajoute, coche, fonce au magasin.</p>

    <% if (typeof error !== 'undefined') { %>
    <!-- On affiche un message d'erreur seulement si la variable "error" a été transmise par le serveur -->
    <p class="erreur"><%= error %></p>
    <% } %>
  </div>

  <div class="courses-section">
    <!-- Fond plein écran (voir .courses-controls-row), mais le contenu reste dans la même
         colonne centrée (max-width 1200px) que le reste de la page : sinon "Trier par" et "+"
         se retrouvaient collés aux bords réels de l'écran au lieu de s'aligner avec le titre
         et les cartes en dessous, comme sur Stock (voir .filters/.filters__inner). -->
    <div class="courses-controls-row">
      <div class="courses-controls-row__inner">
        <div class="sort-wrapper">
          <label for="sortSelectCourses">Trier par :</label>
          <select id="sortSelectCourses">
            <option value="nom">Nom</option>
            <option value="categorie">Catégorie</option>
          </select>
        </div>
        <!-- Interrupteur façon iOS plutôt qu'un bouton pilule classique -->
        <button type="button" id="toggleMagasin" class="toggle-ios">
          <span class="toggle-ios__track"><span class="toggle-ios__thumb"></span></span>
          <span class="toggle-ios__label">Au magasin</span>
        </button>
        <button type="button" id="btnToggleAjoutCourse" class="btn-ajout-icone" title="Ajouter un article">Ajouter un article</button>
      </div>
    </div>

    <!-- Panneau d'ajout : fermé par défaut, ouvert/fermé en cliquant sur le "+" juste au-dessus.
         Même technique d'accordéon que le panneau d'ajout de Stock (voir style.css). -->
    <div id="panneauAjoutCourse" class="panneau-ajout">
      <div class="panneau-ajout__piege">
      <div class="panneau-ajout__interieur">
        <!-- Formulaire pour ajouter un nouvel article à la liste de courses, avec autocomplétion -->
        <form action="/courses/ajouter" method="post" id="formAjouterCourse">
          <!-- Champ caché : rempli par le JavaScript avec l'id de l'aliment choisi dans la liste de suggestions -->
          <input type="hidden" name="idAliment" id="idAlimentCacheCourses" />

          <div id="autocompleteCourses">
            <input type="text" id="rechercheAlimentCourses" name="rechercheAliment" placeholder="Recherche un article..." autocomplete="off" />
            <ul id="listeAlimentsCourses">
              <% aliments.forEach(function(aliment) { %>
              <li data-id="<%= aliment.id %>">
                <%= aliment.emoji %> <%= aliment.nom %>
              </li>
              <% }) %>
            </ul>
          </div>
          <!-- Bouton texte classique (comme #btnAjouter sur Stock), pas un rond "+" : sinon il
               était identique au bouton qui ouvre ce panneau juste au-dessus, ce qui prêtait à
               confusion (les deux étaient un simple rond rouge sans texte visible) -->
          <!-- Caché par défaut : n'apparaît que si le texte tapé ne correspond à aucun aliment
               connu (voir courses.js), pour éviter de proposer un ajout "en texte libre" alors
               qu'il suffit de cliquer la suggestion déjà affichée juste au-dessus -->
          <button type="button" id="btnAjouterCourse" class="hidden">Ajouter</button>
        </form>
      </div>
      </div>
    </div>

    <!-- Ajoute d'un coup les courses habituelles de la semaine, sans effacer ce qui est déjà dans la liste
         (contrairement au bouton recette de la page Calories, qui lui remplace tout) -->
    <button type="button" id="btnPresetHebdo" class="filter-btn btn-preset-hebdo">🧺 Courses de la semaine</button>

    <!-- Liste des articles à acheter, générée côté serveur -->
    <div id="listeCourses">
      <% courses.forEach(function(item) { %>
      <!-- data-nom et data-categorie servent au tri fait en JavaScript ; "zzz" place les articles
           sans catégorie tout à la fin quand on trie par catégorie -->
      <div class="course-item carte-article" data-nom="<%= item.nom.toLowerCase() %>" data-categorie="<%= item.categorie || 'zzz' %>">
        <!-- Combien on en a déjà en stock à la maison (pastille en haut à gauche) :
             un nombre pour les aliments suivis en quantité, un point de couleur pour les "cl" (ex: bouteille) -->
        <% if (item.quantite_stock !== null && item.tracking_type !== 'cl') { %>
        <span class="course-stock-indicator course-stock-badge" title="Déjà <%= item.quantite_stock %> en stock"><%= item.quantite_stock %></span>
        <% } else if (item.quantite_stock !== null && item.tracking_type === 'cl') { %>
        <%
          let classeNiveauCourse = 'niveau-vide';
          if (item.quantite_stock === 'plein') classeNiveauCourse = 'niveau-plein';
          else if (item.quantite_stock === 'à moitié') classeNiveauCourse = 'niveau-moitie';
          else if (item.quantite_stock === 'presque vide') classeNiveauCourse = 'niveau-presque-vide';
        %>
        <span class="course-stock-indicator course-stock-dot <%= classeNiveauCourse %>" title="En stock : <%= item.quantite_stock %>"></span>
        <% } %>
        <!-- Cliquer sur le nom ouvre le champ pour ajouter/modifier une note (voir courses.js) -->
        <span class="course-nom" data-id="<%= item.id %>"><%= item.emoji %> <%= item.nom %></span>

        <!-- Formulaire de suppression, intercepté par courses.js pour l'envoyer sans recharger la page -->
        <form action="/courses/supprimer" method="post" class="form-supprimer">
          <input type="hidden" name="idCourse" value="<%= item.id %>" />
          <button type="submit" class="btn-supprimer-icone btn-supprimer-dash">Supprimer</button>
        </form>

        <!-- La note n'est affichée que si un commentaire existe déjà pour cet article -->
        <% if (item.commentaire) { %>
        <p class="note-affichee" data-id="<%= item.id %>">📝 <%= item.commentaire %></p>
        <% } %>
        <!-- Champ de saisie de la note, cadré par défaut (affiché seulement au clic, voir courses.js) -->
        <input type="text" class="input-commentaire hidden" placeholder="Ajouter une note" value="<%= item.commentaire || '' %>" data-id="<%= item.id %>" />

        <!--
          Le bloc "Acheté" est différent selon le type de l'article :
          - aliment connu suivi en "cl" (ex: bouteille) → juste un bouton (remet le niveau à plein)
          - aliment connu suivi en quantité → un champ de quantité + suggestions rapides (1/2/5)
          - article "libre" (nom tapé à la main, pas encore un aliment connu) → juste un bouton
        -->
        <% if (item.food_id && item.tracking_type === 'cl') { %>
        <form action="/courses/acheter" method="post" class="form-acheter">
          <input type="hidden" name="idCourse" value="<%= item.id %>" />
          <div class="course-item__shop-slot">
            <button type="submit" class="btn-icone-rond btn-acheter-icone">Acheté</button>
          </div>
        </form>
        <% } else if (item.food_id) { %>
        <form action="/courses/acheter" method="post" class="form-acheter form-quantite">
          <input type="hidden" name="idCourse" value="<%= item.id %>" />
          <div class="course-item__quantite-groupe">
            <div class="suggestions-quantite">
              <button type="button" class="suggestion" data-valeur="1">1</button>
              <button type="button" class="suggestion" data-valeur="2">2</button>
              <button type="button" class="suggestion" data-valeur="5">5</button>
            </div>
            <input type="number" name="quantiteAchetee" class="champ-quantite-achat" min="1" placeholder="Quantité" />
          </div>
          <div class="course-item__shop-slot">
            <!-- Ce bouton reste désactivé tant qu'aucune quantité n'a été saisie (activé par courses.js) -->
            <button type="submit" class="btn-icone-rond btn-acheter-icone btn-enregistrer-achat" disabled>Acheté</button>
          </div>
        </form>
        <% } else { %>
        <form action="/courses/acheter" method="post" class="form-acheter">
          <input type="hidden" name="idCourse" value="<%= item.id %>" />
          <div class="course-item__shop-slot">
            <button type="submit" class="btn-icone-rond btn-acheter-icone">Acheté</button>
          </div>
        </form>
        <% } %>
      </div>
      <% }) %>
    </div>

    <script src="/js/courses.js" defer></script>
  </div>
</main>

<%- include('partials/footer') %>
