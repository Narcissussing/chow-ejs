<!-- Ce fichier est inclus en haut de chaque page (via un appel "include" dans les autres vues) -->
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Le titre de l'onglet change selon la page grâce à la variable "title" passée par index.js -->
  <title>Chow — <%= title %></title>
  <!-- Chargement des polices d'écriture personnalisées (Google Fonts) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<!-- Barre de navigation présente en haut de toutes les pages -->
<header class="header">
  <div class="header__inner">
    <a href="/" class="logo">Chow</a>
    <!-- currentPath vient d'un middleware dans index.js (disponible sur toutes les pages) :
         on compare avec chaque lien pour savoir lequel est la page actuelle, et lui donner
         la classe "actif" (stylée en CSS, voir .nav__link.actif) -->
    <nav class="nav">
      <a href="/aliments" class="nav__link <%= currentPath.startsWith('/aliments') ? 'actif' : '' %>">Aliments</a>
      <a href="/stock" class="nav__link <%= currentPath.startsWith('/stock') ? 'actif' : '' %>">Stock</a>
      <a href="/courses" class="nav__link <%= currentPath.startsWith('/courses') ? 'actif' : '' %>">Courses</a>
      <a href="/calories" class="nav__link <%= currentPath.startsWith('/calories') ? 'actif' : '' %>">Calories</a>
    </nav>
  </div>
</header>
<script>
  // La barre de filtres (Aliments/Stock) et la barre de contrôles (Courses) se collent juste
  // sous ce header au scroll (voir .filters et .courses-controls-row en CSS). Leur "top" ne
  // peut pas être une valeur fixe en dur : la hauteur réelle du header change selon l'écran
  // (padding mobile, retour à la ligne du logo...) et une valeur figée finissait décalée sur
  // certains téléphones, faisant passer la barre à moitié sous le header au lieu de rester
  // collée juste en dessous. On mesure donc la vraie hauteur et on la publie en variable CSS.
  (function () {
    function publierHauteurHeader() {
      var header = document.querySelector(".header");
      if (header) {
        document.documentElement.style.setProperty("--header-h", header.offsetHeight + "px");
      }
    }
    publierHauteurHeader();
    window.addEventListener("resize", publierHauteurHeader);
  })();
</script>
