<%- include('partials/header') %>

<main>
  <h1>Stock</h1>
  <% stock.forEach(function(aliment) { %>
  <p><%= aliment.nom %></p>
  <% if (aliment.tracking_type === 'cl') { %>
  <p><%= aliment.quantite %></p>
  <% } else { %>
  <p><%= aliment.quantite %> <%= aliment.unite %></p>
  <% } %>
  <% if (aliment.jours_depuis === 0) { %>
  <p>aujourd'hui</p>
  <% } else if (aliment.jours_depuis === 1) { %>
  <p>il y a 1 jour</p>
  <% } else { %>
  <p>il y a <%= aliment.jours_depuis %> jours</p>
  <% } %>

  <% if (aliment.tracking_type === 'cl') { %>
  <form action="/stock/modifier" method="post" class="form-modif">
    <input type="hidden" name="idStock" value="<%= aliment.id %>" />
    <select name="nouvelleQuantite" class="champ-modif" data-initial="<%= aliment.quantite %>" disabled>
      <option value="plein" <%= aliment.quantite === 'plein' ? 'selected' : '' %>>Plein</option>
      <option value="à moitié" <%= aliment.quantite === 'à moitié' ? 'selected' : '' %>>À moitié</option>
      <option value="presque vide" <%= aliment.quantite === 'presque vide' ? 'selected' : '' %>>Presque vide</option>
      <option value="vide" <%= aliment.quantite === 'vide' ? 'selected' : '' %>>Vide</option>
    </select>
    <button type="button" class="btn-editer">Modifier</button>
    <button type="submit" class="btn-sauvegarder" disabled hidden>Enregistrer</button>
  </form>
  <% } else { %>
  <form action="/stock/modifier" method="post" class="form-modif">
    <input type="hidden" name="idStock" value="<%= aliment.id %>" />
    <input type="number" name="nouvelleQuantite" class="champ-modif" value="<%= aliment.quantite %>" data-initial="<%= aliment.quantite %>" min="0" disabled />
    <button type="button" class="btn-editer">Modifier</button>
    <button type="submit" class="btn-sauvegarder" disabled hidden>Enregistrer</button>
  </form>
  <% } %>

  <form action="/stock/supprimer" method="post">
    <input type="hidden" name="idStock" value="<%= aliment.id %>" />
    <button type="submit">Supprimer</button>
  </form>
  <% }) %>

  <form action="/stock/ajouter" method="post">
    <input type="hidden" name="idAliment" id="idAlimentCache" />

    <div id="autocomplete">
      <input type="text" id="rechercheAliment" placeholder="Rechercher un aliment..." autocomplete="off" />
      <ul id="listeAliments">
        <% aliments.forEach(function(aliment) { %>
        <li data-id="<%= aliment.id %>" data-type="<%= aliment.tracking_type %>">
          <%= aliment.emoji %> <%= aliment.nom %>
        </li>
        <% }) %>
      </ul>
    </div>

    <input type="number" name="quantiteAliment" id="champQuantite" placeholder="Quantité" min="1" disabled />
    <select name="quantiteAliment" id="champCL" disabled>
      <option value="">-- Choisir --</option>
      <option value="plein">Plein</option>
      <option value="à moitié">À moitié</option>
      <option value="presque vide">Presque vide</option>
      <option value="vide">Vide</option>
    </select>
    <button type="submit" id="btnAjouter" disabled>Ajouter</button>
  </form>

  <script src="/js/stock.js" defer></script>
</main>

<%- include('partials/footer') %>