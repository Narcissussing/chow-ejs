<%- include('partials/header') %>

<main>
  <div class="page-header">
    <h1>Stock</h1>
    <% if (typeof error !== 'undefined') { %>
    <!-- On affiche un message d'erreur seulement si la variable "error" a été transmise par le serveur -->
    <p class="erreur"><%= error %></p>
    <% } %>
  </div>

  <!-- Boutons de filtre par emplacement : cliquer dessus ne recharge pas la page,
       c'est du JavaScript (public/js/stock.js) qui cache/affiche les articles.
       Même barre pleine largeur que sur Aliments, pour que les deux pages se ressemblent. -->
  <div class="filters">
    <div class="filters__inner">
      <div class="filter-buttons">
        <button type="button" class="filter-btn active" data-emplacement="tous">Tous</button>
        <button type="button" class="filter-btn" data-emplacement="fg">🧊 Frigo</button>
        <button type="button" class="filter-btn" data-emplacement="fz">❄️ Congélateur</button>
        <button type="button" class="filter-btn" data-emplacement="st">📦 Réserve</button>
      </div>
    </div>
  </div>

  <div class="stock-section">
    <!-- Barre de recherche + menu de tri, également gérés par stock.js -->
    <div class="search-sort-wrapper">
      <div class="search-wrapper">
        <input type="text" id="searchInput" placeholder="Rechercher dans le stock..." autocomplete="off" />
      </div>
      <div class="sort-wrapper">
        <label for="sortSelect">Trier par :</label>
        <select id="sortSelect">
          <option value="alpha">Nom</option>
          <option value="ancien">Ancien</option>
          <option value="recent">Récent</option>
        </select>
      </div>
    </div>

    <!-- Bouton qui ouvre/ferme le panneau d'ajout d'un aliment au stock -->
    <button type="button" id="btnToggleAjout" class="filter-btn">+ Ajouter un aliment</button>

    <!-- Panneau d'ajout : fermé par défaut, ouvert/fermé en cliquant sur le bouton ci-dessus.
         La classe "ouvert" (ajoutée/retirée par stock.js) anime la hauteur du panneau (voir style.css) -->
    <div id="panneauAjoutStock" class="panneau-ajout">
      <div class="panneau-ajout__piege">
      <div class="panneau-ajout__interieur">
        <form action="/stock/ajouter" method="post" id="formAjouterStock">
          <!-- Champ caché : stocke l'id de l'aliment choisi dans la liste de suggestions, rempli par le JavaScript -->
          <input type="hidden" name="idAliment" id="idAlimentCache" />

          <div id="autocomplete">
            <input type="text" id="rechercheAliment" placeholder="Rechercher un aliment..." autocomplete="off" />
            <!-- La liste complète des aliments est générée ici côté serveur (avec EJS),
                 puis filtrée dynamiquement par le JavaScript selon ce que l'utilisateur tape -->
            <ul id="listeAliments">
              <% aliments.forEach(function(aliment) { %>
              <li data-id="<%= aliment.id %>" data-type="<%= aliment.tracking_type %>">
                <%= aliment.emoji %> <%= aliment.nom %>
              </li>
              <% }) %>
            </ul>
          </div>

          <!-- Ces deux champs sont cachés au départ : le JavaScript n'en affiche qu'un seul,
               selon le type de suivi (tracking_type) de l'aliment sélectionné -->
          <input type="number" name="quantiteAliment" id="champQuantite" placeholder="Quantité" min="1" class="hidden" disabled />
          <select name="quantiteAliment" id="champCL" class="hidden" disabled>
            <option value="">-- Choisir --</option>
            <option value="plein">Plein</option>
            <option value="à moitié">À moitié</option>
            <option value="presque vide">Presque vide</option>
            <option value="vide">Vide</option>
          </select>
          <button type="submit" id="btnAjouter" disabled>Ajouter</button>
        </form>
      </div>
      </div>
    </div>

    <!-- Liste des articles actuellement en stock, générée côté serveur -->
    <div id="listeStock">
      <% stock.forEach(function(aliment) { %>
      <!-- Chaque article stocke ses infos dans des attributs data-*, réutilisés ensuite par stock.js
           pour filtrer, trier, et savoir comment l'afficher/le modifier sans recharger la page -->
      <div
        class="stock-item carte-article"
        data-id="<%= aliment.id %>"
        data-nom="<%= aliment.nom.toLowerCase() %>"
        data-emplacement="<%= aliment.emplacement %>"
        data-tracking-type="<%= aliment.tracking_type %>"
        data-jours="<%= aliment.jours_depuis %>"
      >
        <!-- On affiche la vraie photo si elle existe, sinon l'emoji comme solution de secours -->
        <% if (aliment.image) { %>
        <img src="/<%= aliment.image %>" alt="<%= aliment.nom %>" class="stock-item__img" />
        <% } else { %>
        <div class="stock-item__emoji"><%= aliment.emoji %></div>
        <% } %>

        <div class="stock-item__body">
          <div class="stock-item__infos">
            <div class="stock-item__ligne stock-item__ligne--nom">
              <span class="stock-nom"><%= aliment.nom %></span>
            </div>
            <!-- Emplacement + fraîcheur, séparés par un "|", sur une deuxième ligne sous un filet horizontal -->
            <div class="stock-item__ligne stock-item__ligne--meta">
              <span class="stock-emplacement">
                <% if (aliment.emplacement === 'fg') { %>Frigo
                <% } else if (aliment.emplacement === 'fz') { %>Congélateur
                <% } else { %>Réserve
                <% } %>
              </span>
              <span class="stock-separateur">|</span>
              <!-- Affichage du nombre de jours depuis la dernière mise à jour, avec un texte adapté selon le cas -->
              <% if (aliment.jours_depuis === 0) { %>
              <span class="stock-jours">aujourd'hui</span>
              <% } else if (aliment.jours_depuis === 1) { %>
              <span class="stock-jours">il y a 1 jour</span>
              <% } else { %>
              <span class="stock-jours">il y a <%= aliment.jours_depuis %> jours</span>
              <% } %>
            </div>
          </div>

          <!-- Zone cliquable pour modifier la quantité : le contenu affiché dépend du type de suivi de l'aliment.
               Sépararée du bloc nom/emplacement par un filet vertical, et centrée sur toute la hauteur des deux lignes. -->
          <div class="stock-editable-zone" data-valeur-actuelle="<%= aliment.quantite %>">
            <% if (aliment.tracking_type === 'cl') { %>
            <!--
              Pour les aliments suivis en "cl" (ex: une bouteille), on affiche une petite barre
              dont le remplissage dépend du niveau actuel (plein / à moitié / presque vide / vide)
            -->
            <%
              let classeNiveau = 'niveau-vide';
              if (aliment.quantite === 'plein') classeNiveau = 'niveau-plein';
              else if (aliment.quantite === 'à moitié') classeNiveau = 'niveau-moitie';
              else if (aliment.quantite === 'presque vide') classeNiveau = 'niveau-presque-vide';
            %>
            <div class="stock-barre-cl" title="<%= aliment.quantite %>">
              <div class="stock-barre-cl-remplissage <%= classeNiveau %>"></div>
            </div>
            <% } else { %>
            <!-- Pour les autres aliments (unités, packs), on affiche simplement le nombre -->
            <span class="stock-quantite"><%= aliment.quantite %></span>
            <% } %>
          </div>
        </div>

        <!-- Formulaire de suppression : normalement il rechargerait la page en soumettant vers /stock/supprimer,
             mais le JavaScript intercepte cet envoi pour le faire en arrière-plan (voir stock.js) -->
        <form action="/stock/supprimer" method="post" class="form-supprimer-stock">
          <input type="hidden" name="idStock" value="<%= aliment.id %>" />
          <button type="submit" class="btn-supprimer-icone btn-supprimer-dash">Supprimer</button>
        </form>
      </div>
      <% }) %>
    </div>

    <!-- Message affiché uniquement quand un filtre/recherche ne donne aucun résultat (géré par stock.js) -->
    <p class="no-results hidden" id="noResultsStock">Aucun article ne correspond à ce filtre.</p>

    <script src="/js/stock.js" defer></script>
  </div>
</main>

<%- include('partials/footer') %>
